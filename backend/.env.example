# GitHub Graph Backend — Environment Variables
# Copy this file to .env and fill in values as needed.

# Server
PORT=3001
NODE_ENV=development

# GitHub personal access token — greatly increases API rate limits (5000 vs 60 req/hr)
# Create one at https://github.com/settings/tokens (no scopes needed for public repos)
# GITHUB_TOKEN=ghp_your_token_here

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting — max requests per window per IP
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000

# Analysis limits
MAX_FILES=5000
DOWNLOAD_TIMEOUT_MS=120000

# Sentry error tracking (optional — get DSN from sentry.io)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx  (frontend, set in Vercel env vars)

# GitHub OAuth App — enables private repo access
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Homepage URL: https://your-app.vercel.app
# Callback URL: https://your-app.vercel.app/api/auth/callback
# GITHUB_CLIENT_ID=your_client_id
# GITHUB_CLIENT_SECRET=your_client_secret
# FRONTEND_URL=https://your-app.vercel.app

# ── Vercel deployment ──────────────────────────────────────────────────────────
# On Vercel Hobby plan: max function duration is 60s (set RATE_LIMIT_MAX=5 to reduce load)
# On Vercel Pro plan:   max function duration is 300s (matches PIPELINE_TIMEOUT_MS default)
# Set GITHUB_TOKEN on Vercel to avoid 60 req/hr rate limits:
#   vercel env add GITHUB_TOKEN
# Set CORS_ORIGINS to your Vercel deployment URL:
#   CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173
