{
  "version": 2,
  "buildCommand": "cd backend && npm ci && npm run build && cd ../frontend && npm ci && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "echo 'installs handled in buildCommand'",
  "functions": {
    "api/index.ts": {
      "maxDuration": 300,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/health",     "destination": "/api/index" },
    { "source": "/health/:path*", "destination": "/api/index" },
    { "source": "/((?!api|health).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
