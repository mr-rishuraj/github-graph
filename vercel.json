{
  "version": 2,
  "buildCommand": "npm install && cd backend && npm ci && npm run build && cd ../frontend && npm ci && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 300,
      "memory": 1024,
      "includeFiles": "backend/dist/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*",    "destination": "/api/index" },
    { "source": "/health",         "destination": "/api/index" },
    { "source": "/health/:path*", "destination": "/api/index" },
    { "source": "/((?!api|health).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
